<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/window_background_color_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">



            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/box64"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="@string/box64_preset" />

                    <Spinner
                        style="@style/ComboBox"
                        android:id="@+id/SBox64Preset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="@color/white"
                        android:spinnerMode="dialog" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:paddingTop="8dp">

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTAddBox64Preset"
                        android:tooltipText="Add"
                        android:tint="@color/white"
                        android:src="@drawable/icon_add" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTEditBox64Preset"
                        android:tooltipText="Edit"
                        android:tint="@color/white"
                        android:src="@drawable/icon_edit" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:tooltipText="Duplicate"
                        android:id="@+id/BTDuplicateBox64Preset"
                        android:tint="@color/white"
                        android:src="@drawable/icon_duplicate" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:tooltipText="Remove"
                        android:id="@+id/BTRemoveBox64Preset"
                        android:tint="@color/white"
                        android:src="@drawable/icon_remove" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTExportBox64Preset"
                        android:tooltipText="Export"
                        android:tint="@color/white"
                        android:src="@drawable/icon_export" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:tooltipText="Import"
                        android:id="@+id/BTImportBox64Preset"
                        android:tint="@color/white"
                        android:src="@drawable/icon_popup_menu_download" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fexcore_config"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="@string/fexcore_preset" />

                    <Spinner
                        style="@style/ComboBox"
                        android:id="@+id/SFEXCorePreset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="@color/white"
                        android:spinnerMode="dialog" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:paddingTop="8dp">

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTAddFEXCorePreset"
                        android:tooltipText="Add"
                        android:tint="@color/white"
                        android:src="@drawable/icon_add" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTEditFEXCorePreset"
                        android:tooltipText="Edit"
                        android:tint="@color/white"
                        android:src="@drawable/icon_edit" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:tooltipText="Duplicate"
                        android:id="@+id/BTDuplicateFEXCorePreset"
                        android:tint="@color/white"
                        android:src="@drawable/icon_duplicate" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:tooltipText="Remove"
                        android:id="@+id/BTRemoveFEXCorePreset"
                        android:tint="@color/white"
                        android:src="@drawable/icon_remove" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTExportFEXCorePreset"
                        android:tooltipText="Export"
                        android:tint="@color/white"
                        android:src="@drawable/icon_export" />

                    <ImageButton
                        style="@style/ListMenuButton"
                        android:tooltipText="Import"
                        android:id="@+id/BTImportFEXCorePreset"
                        android:tint="@color/white"
                        android:src="@drawable/icon_popup_menu_download" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sound"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/midi_sound_font" />

                <Spinner
                    android:id="@+id/SMIDISoundFont"
                    style="@style/ComboBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/BTInstallSF"
                    style="@style/ListMenuButton"
                    android:tint="@color/white"
                    android:src="@drawable/icon_add" />

                <ImageButton
                    android:id="@+id/BTRemoveSF"
                    style="@style/ListMenuButton"
                    android:tint="@color/white"
                    android:src="@drawable/icon_remove" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Theme"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <CheckBox
                    android:id="@+id/CBDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="Enable Dark Mode" />
            </LinearLayout>

            <!-- Steam Settings -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Steam Integration"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/BTSteamLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#37474F"
                    android:textColor="@color/white"
                    android:text="Login to Steam" />
                <Button
                    android:id="@+id/BTSteamLibrary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#37474F"
                    android:textColor="@color/white"
                    android:text="View Steam Library" />
                <TextView
                    android:id="@+id/TVSteamStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/gray"
                    android:text="Status: Not Logged In"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Shortcuts -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Path Settings"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="Winlator Path" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:id="@+id/TVWinlatorPath"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:layout_weight="1" />
                    <Button
                        android:id="@+id/BTChooseWinlatorPath"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#37474F"
                        android:textColor="@color/white"
                        android:text="Choose Path" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="Shortcut Export Path" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/TVShortcutExportPath"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:layout_weight="1" />
                    <Button
                        android:id="@+id/BTChooseShortcutExportPath"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#37474F"
                        android:textColor="@color/white"
                        android:text="Choose Path" />
                </LinearLayout>

            </LinearLayout>

            <!-- Big Picture Mode -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Big Picture Mode"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <CheckBox
                    android:id="@+id/CBEnableBigPictureMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="Enable Big Picture Mode on App Launch" />

                <View style="@style/HorizontalLine" android:layout_marginVertical="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/CBEnableCustomApiKey"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="Set SteamGrid API Key? (Cover Art)" />

                    <ImageView
                        android:id="@+id/BTHelpApiKey"
                        style="@style/HelpButton"
                        android:contentDescription="@string/help_steamgrid"
                        android:tint="@color/white"
                        android:src="@drawable/icon_help" />
                </LinearLayout>

                <EditText
                    android:id="@+id/ETCustomApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gray"
                    android:background="@drawable/edit_text_dark"
                    android:hint="Enter your API Key here"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/xserver"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/white"
                        android:text="@string/cursor_speed"/>

                    <TextView
                        android:id="@+id/TVCursorSpeed"
                        android:layout_width="wrap_content"
                        android:textColor="@color/white"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/SBCursorSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:min="10"
                    android:max="200" />

                <CheckBox
                    android:id="@+id/CBUseDRI3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/use_dri3_extension"
                    android:layout_marginTop="8dp" />

                <CheckBox
                    android:id="@+id/CBUseXR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/use_xr"
                    android:layout_marginTop="8dp" />

                <!-- New Cursor Lock Checkbox -->
                <CheckBox
                    android:id="@+id/CBCursorLock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="True Mouse Control (Deactivate with Volume Down)"
                    android:layout_marginTop="8dp" />

                <!-- New Xinput Toggle Checkbox -->
                <CheckBox
                    android:id="@+id/CBXinputToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="Disable Xinput (Used for Exclusive M/KB support)"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/logs"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <CheckBox
                    android:id="@+id/CBEnableWineDebug"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/enable_wine_debug" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/LLWineDebugChannels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="4dp" />
                </HorizontalScrollView>

                <View style="@style/HorizontalLine" android:layout_marginVertical="8dp"/>

                <CheckBox
                    android:id="@+id/CBEnableBox64Logs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/enable_box64_logs"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/components"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/CBEnableFileProvider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:text="@string/enable_file_provider" />

                    <ImageView
                        android:id="@+id/BTHelpFileProvider"
                        style="@style/HelpButton"
                        android:tint="@color/white"
                        android:layout_gravity="center" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/CBOpenWithAndroidBrowser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/open_with_android_browser" />

                <CheckBox
                    android:id="@+id/CBShareAndroidClipboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/share_android_clipboard" />

                <View style="@style/HorizontalLine" android:layout_marginVertical="8dp"/>

                <Button
                    android:id="@+id/BTContentManager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#37474F"
                    android:textColor="@color/white"
                    android:text="Content Manager" />

                <Button
                    android:id="@+id/BTDriverManager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#37474F"
                    android:textColor="@color/white"
                    android:text="Driver Manager" />

                <View style="@style/HorizontalLine" android:layout_marginVertical="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="Downloadable Contents URL" />

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:background="@drawable/edit_text_dark"
                    android:id="@+id/ETDownloadableContentsURL"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/imagefs"
                android:textColor="#1A9FFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_layout_background_dark"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/BTReInstallImagefs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#37474F"
                    android:textColor="@color/white"
                    android:text="@string/reinstall_imagefs" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/BTConfirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right|bottom"
        android:tint="#ffffff"
        android:src="@drawable/icon_confirm"
        app:backgroundTint="#1A9FFF"
        android:layout_margin="16dp" />

</FrameLayout>
